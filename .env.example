# Public Supabase browser configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only authentication and AI configuration
SUPABASE_SERVICE_ROLE_KEY=
# A server-only random value used to hash AI request identities before durable limiting.
MOMO_RATE_LIMIT_SALT=
# Guest AI requests allowed per visitor per rolling calendar day (1-500).
MOMO_GUEST_AI_DAILY_LIMIT=30
OPENAI_API_KEY=
MOMO_AI_PROVIDER=openai
MOMO_AI_MODE=gpt56_review

# Luna is the affordable default for low-risk explanation and triage.
MOMO_OPENAI_QUICK_MODEL=gpt-5.6-luna
MOMO_OPENAI_RESEARCH_MODEL=gpt-5.6-luna
# Terra is used only when a traveller requests a deeper evidence review.
MOMO_OPENAI_DEEP_MODEL=gpt-5.6-terra

# Keep false unless you intentionally want Gemini as an outage fallback.
MOMO_GEMINI_FALLBACK=false
